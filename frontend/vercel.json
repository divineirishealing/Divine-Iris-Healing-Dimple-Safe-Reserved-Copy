{
  "ignoreCommand": "node scripts/vercel-ignore-duplicate-projects.cjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "divine-iris-healing-dimple-safe-res.vercel.app" }],
      "destination": "https://divineirishealing.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://divine-iris-backend.onrender.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "outputDirectory": "build",
  "framework": "create-react-app"
}
