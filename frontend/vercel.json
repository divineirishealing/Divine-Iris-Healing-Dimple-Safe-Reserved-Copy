{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "divine-iris-healing-dimple-safe-res.vercel.app" }],
      "destination": "https://divineirishealing.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "outputDirectory": "build",
  "framework": "create-react-app"
}
