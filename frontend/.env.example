# Copy to .env.local for local dev. Vercel/Render static: set the same key in the dashboard.
# No trailing slash — must match your Render (or other) API host.
REACT_APP_BACKEND_URL=https://your-api-host.onrender.com

# Optional: if your host rewrites /api/* to the backend (e.g. Vercel), set to 1 so the bundle calls same-origin /api.
# REACT_APP_SAME_ORIGIN_API=1
