# ─────────────────────────────────────────────
# REQUIRED — backend will not start without these
# ─────────────────────────────────────────────
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>
DB_NAME=divineIris

# ─────────────────────────────────────────────
# REQUIRED — your Render backend public URL
# Used for Stripe redirect URLs and email links
# ─────────────────────────────────────────────
HOST_URL=https://your-service-name.onrender.com

# Public marketing site (Vercel custom domain). Used for reminder links, emails, etc.
FRONTEND_URL=https://divineirishealing.com

# Browser origins allowed to call this API (comma-separated). Must include your live site + www.
# ALLOWED_ORIGINS=https://divineirishealing.com,https://www.divineirishealing.com

# ─────────────────────────────────────────────
# Google Sign-In (student portal OAuth)
# ─────────────────────────────────────────────
# 1) Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
# 2) Authorized redirect URI(s) must include EXACTLY the callback URL the API uses:
#      https://<your-backend-public-host>/api/auth/google/callback
#    Local: http://localhost:8001/api/auth/google/callback (if HOST_URL / request host matches).
#    If you use a custom domain or proxy, set GOOGLE_OAUTH_REDIRECT_URI to the same string
#    you registered in Google Console (must match token exchange redirect_uri byte-for-byte).
# 3) Same email must exist in Client Garden with portal_login_allowed if you gate portal access.
#
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
# GOOGLE_OAUTH_REDIRECT_URI=https://your-service.onrender.com/api/auth/google/callback

# ─────────────────────────────────────────────
# OPTIONAL — can be set via Admin Panel instead
# These are fallbacks; the app reads from MongoDB first
# ─────────────────────────────────────────────
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...   # Get from Stripe Dashboard > Webhooks

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password       # Gmail App Password (not your account password)

RESEND_API_KEY=re_...             # Optional backup email service

# NOTE: Sender email and receipt email addresses are configured
# through the Admin Panel inside the app (Settings > API Keys).
# You do NOT need to set them here.

# ─────────────────────────────────────────────
# OPTIONAL — AWS S3 for durable image/video uploads (recommended on Render)
# ─────────────────────────────────────────────
# Create a bucket in the SAME region as AWS_REGION. IAM user policy (example):
#   s3:PutObject, s3:GetObject, s3:DeleteObject on arn:aws:s3:::YOUR_BUCKET_NAME/uploads/*
# Bucket policy so browsers can load images (adjust prefix if AWS_S3_PREFIX is not "uploads"):
# {
#   "Version": "2012-10-17",
#   "Statement": [{
#     "Sid": "PublicReadUploads",
#     "Effect": "Allow",
#     "Principal": "*",
#     "Action": "s3:GetObject",
#     "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/uploads/*"
#   }]
# }
# If Object Ownership is "Bucket owner enforced", do NOT set AWS_S3_OBJECT_ACL.
# If you use older ACL-based public objects, set: AWS_S3_OBJECT_ACL=public-read
#
# AWS_S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=ap-southeast-1
# AWS_S3_PREFIX=uploads
# AWS_S3_PUBLIC_BASE_URL=   # optional: https://d123.cloudfront.net  (no trailing slash)
# AWS_S3_USE_IAM_ROLE=false
# AWS_S3_OBJECT_ACL=
# AWS_S3_ADDRESSING_STYLE=
# REQUIRE_S3_FOR_UPLOADS=true   # optional: forbid local-disk fallback for images, videos, docs, payment proofs
#
# Recommended: use native S3 URLs in Mongo (default):
#   S3_URL_FOR_BROWSER=direct
# and EITHER a bucket policy allowing s3:GetObject on uploads/* (see policy above)
# OR (keep bucket private) set all of:
#   HOST_URL=https://your-backend.onrender.com
#   S3_PROXY_VIRTUAL_HOST_URLS=true
# The app will rewrite my-bucket.s3.region.amazonaws.com/... links to HOST_URL/api/s3-media/... (IAM needs s3:GetObject).
