# Copy to .env and adjust.
#
# Personalized replies (recommended): OpenAI reads each comment + video title.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: override default tone/rules (otherwise a warm creator default is used)
# YT_REPLY_SYSTEM_PROMPT=
#
# Used when OPENAI_API_KEY is unset, or if the API errors (always set for safety)
YT_REPLY_TEMPLATE=Thank you so much for your comment — I really appreciate you being here.

# Max characters per posted reply (default 600)
# MAX_REPLY_CHARS=600

# Safety limits (YouTube API: each reply costs ~50 quota units; default daily quota is 10_000)
MAX_VIDEOS_PER_RUN=30
MAX_REPLIES_PER_RUN=25

# Set to 1 to print actions without posting
DRY_RUN=0
