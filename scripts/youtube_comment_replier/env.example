# Copy to .env and adjust.
#
# Personalized replies (recommended): OpenAI reads each comment + video title.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: full override of AI rules (otherwise a warm creator default is used).
# YT_REPLY_SYSTEM_PROMPT=
#
# Recommended: short "sounds like me" notes appended to the default rules (no need to duplicate the full prompt).
# Example (one paragraph or several lines; use \n in .env or a single line):
# YT_REPLY_PERSONA=Warm, grounded, spiritual but not preachy. I often say "thank you for being here" and sign with love/light. I never argue in comments.
#
# YT_REPLY_PERSONA=
#
# Steadier voice: 0.45–0.55. Slightly more varied: 0.65–0.75 (default 0.65).
# YT_REPLY_TEMPERATURE=0.55
#
# Used when OPENAI_API_KEY is unset, or if the API errors (always set for safety)
YT_REPLY_TEMPLATE=Thank you so much for your comment — I really appreciate you being here.

# Max characters per posted reply (default 600)
# MAX_REPLY_CHARS=600

# Safety limits (YouTube API: each reply costs ~50 quota units; default daily quota is 10_000)
MAX_VIDEOS_PER_RUN=30
MAX_REPLIES_PER_RUN=25

# Set to 1 to print actions without posting
DRY_RUN=0
