# Instagram Graph API — Content Publishing (feed image posts)
#
# You need: Instagram Business OR Creator account linked to a Facebook Page
# and a Facebook app with Instagram product + permissions (see post_to_instagram.py docstring).
#
# Use a long-lived Page access token with: instagram_basic, instagram_content_publish,
# pages_read_engagement, pages_show_list (as required by your app in Meta).
#
# Required for posting
FACEBOOK_PAGE_ID=
# Page access token (from Business Suite / Graph API Explorer / token exchange)
FACEBOOK_PAGE_ACCESS_TOKEN=
#
# Optional: if you already know your Instagram professional account id (numeric)
# INSTAGRAM_USER_ID=
#
# Optional: AI-drafted caption (same OpenAI key pattern as youtube_comment_replier)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional extra voice lines for generated captions
# INSTAGRAM_CAPTION_PERSONA=

# Dry run: set to 1 to only print what would be sent (no post)
# DRY_RUN=0
